<?xml version="1.0" encoding="UTF-8"?>

<?import javafx.geometry.*?>
<?import javafx.scene.control.*?>
<?import javafx.scene.layout.*?>
<?import javafx.scene.text.*?>

<VBox fx:id="root" alignment="CENTER" spacing="20" style="-fx-background-color: white; -fx-background-radius: 10;" styleClass="root" xmlns="http://javafx.com/javafx/17.0.12" xmlns:fx="http://javafx.com/fxml/1" fx:controller="org.example.fripouilles.controller.LoginController">

    <padding>
        <Insets bottom="40" left="40" right="40" top="40" />
    </padding>

    <!-- En-tête -->
    <VBox alignment="CENTER" spacing="10">
        <Label styleClass="title" text="RAM Les Fripouilles">
            <font>
                <Font name="System Bold" size="24" />
            </font>
        </Label>
        <Label styleClass="subtitle" text="Gestion des Paies - Connexion">
            <font>
                <Font size="14" />
            </font>
        </Label>
    </VBox>

    <!-- Formulaire de connexion -->
    <VBox spacing="15" style="-fx-background-color: #f5f5f5; -fx-padding: 30; -fx-background-radius: 5;">
        <Label text="Email:">
            <font>
                <Font name="System Bold" size="12" />
            </font>
        </Label>
        <TextField fx:id="emailField" prefWidth="300" promptText="Entrez votre email" />

        <Label text="Mot de passe:">
            <font>
                <Font name="System Bold" size="12" />
            </font>
        </Label>
        <PasswordField fx:id="passwordField" prefWidth="300" promptText="Entrez votre mot de passe" />

        <!-- Boutons -->
        <HBox alignment="CENTER" spacing="10">
            <padding>
                <Insets top="10" />
            </padding>
            <Button defaultButton="true" onAction="#handleLogin" prefWidth="120" style="-fx-background-color: #0092b8; -fx-text-fill: white; -fx-font-weight: bold;" text="Se connecter" />
            <Button cancelButton="true" onAction="#handleCancel" prefWidth="120" style="-fx-background-color: #f44336; -fx-text-fill: white;" text="Annuler" />
        </HBox>
    </VBox>

    <!-- Pied de page -->
    <Label style="-fx-text-fill: #757575; -fx-font-size: 10;" text="© 2026 RAM Les Fripouilles">
        <padding>
            <Insets top="20" />
        </padding>
    </Label>
</VBox>