          },
          "codePostal": {
            "type": "string",
            "example": "75001",
            "description": "Code postal"
          },
          "ville": {
            "type": "string",
            "example": "Paris",
            "description": "Ville"
          },
          "situationFamiliale": {
            "type": "string",
            "example": "Marié(e)",
            "description": "Situation familiale"
          },
          "profession": {
            "type": "string",
            "example": "Ingénieur",
            "description": "Profession"
          },
          "employeur": {
            "type": "string",
            "example": "Entreprise XYZ",
            "description": "Employeur"
          },
          "numeroAllocataire": {
            "type": "string",
            "example": "1234567",
            "description": "Numéro allocataire"
          },
          "beneficiaireCAF": {
            "type": "boolean",
            "example": true,
            "description": "Bénéficiaire CAF"
          },
          "numeroCAF": {
            "type": "string",
            "example": "1234567X",
            "description": "Numéro CAF"
          },
          "contactUrgenceNom": {
            "type": "string",
            "example": "Marie Dupont",
            "description": "Nom du contact d'urgence"
          },
          "contactUrgenceTel": {
            "type": "string",
            "example": "06 12 34 56 78",
            "description": "Téléphone du contact d'urgence"
          }
        },
        "required": [
          "adresse",
          "codePostal",
          "ville",
          "situationFamiliale",
          "contactUrgenceNom",
          "contactUrgenceTel"
        ]
      },
      "CreateAssistantProfilDto": {
        "type": "object",
        "properties": {
          "adresse": {
            "type": "string",
            "example": "25 avenue des Lilas",
